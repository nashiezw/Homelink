DATABASE_URL="postgresql://postgres:postgres@localhost:5432/homelink"
# When DATABASE_URL points to PostgreSQL, the full marketplace store snapshot is persisted there.
# Without PostgreSQL, operational data falls back to .data/app-store.json on disk.
SETTINGS_DATABASE_URL="file:./.data/settings.db"
NEXT_PUBLIC_APP_URL="https://homelinkzim.co.zw"
# Set to true in the final production environment. This makes unsafe launch
# defaults fail closed instead of silently using local/sandbox fallbacks.
HOMELINK_STRICT_PRODUCTION="false"

# Configure one provider when auth is implemented.
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
FIREBASE_PROJECT_ID=""

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""

# Local seed credentials. Override these in staging/production and keep real values out of source control.
SEED_STANDARD_PASSWORD="HomeLink2026!"
SEED_TINASHE_PASSWORD="HomeLink2026!"
SEED_LANDLORD_PASSWORD="HomeLinkOwner2026!"
SEED_ADMIN_PASSWORD="HomeLinkAdmin2026!"
SEED_CONSULTANT_PASSWORD="HomeLinkConsultant2026!"
