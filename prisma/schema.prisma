generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SEEKER
  LANDLORD
  AGENT
  AGENCY_ADMIN
  ADMIN
  SUPER_ADMIN
  ACADEMY_ADMIN
  TRAINER
  PUBLIC_LEARNER
  MODERATOR
}

enum ListingIntent {
  RENT
  BUY
}

enum PropertyType {
  ROOM
  HOUSE
  FLAT
  COTTAGE
  COMMERCIAL
  LAND
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  VIEWING_IN_PROGRESS
  RENTED
  SOLD
  SUSPENDED
  EXPIRED
  REJECTED
  ARCHIVED
  DELETED
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum PaymentProvider {
  STRIPE
  PAYNOW
  ECOCASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum LeadSource {
  HOMELINK
  AGENT
}

enum AgentCommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
  DISPUTED
}

enum CommissionRuleScope {
  DEFAULT
  AGENT
  TRANSACTION
  BRANCH
  PROPERTY_TYPE
  PROMOTION
  AGENT_LEVEL
}

enum LeadOwnershipReviewStatus {
  NOT_REQUIRED
  PENDING_ADMIN_REVIEW
  CLEARED
  DUPLICATE_BLOCKED
}

model User {
  id                String                    @id @default(cuid())
  email             String                    @unique
  phone             String?                   @unique
  passwordHash      String?
  accountStatus     String                    @default("ACTIVE")
  name              String
  roles             Role[]                    @default([SEEKER])
  identityStatus    VerificationStatus        @default(PENDING)
  phoneVerifiedAt   DateTime?
  emailVerifiedAt   DateTime?
  createdAt         DateTime                  @default(now())
  lastLoginAt       DateTime?
  updatedAt         DateTime                  @updatedAt
  listings          Listing[]
  favourites        Favourite[]
  savedSearches     SavedSearch[]
  roommateProfile   RoommateProfile?
  reviewsGiven      Review[]                  @relation("ReviewAuthor")
  enquiries         Enquiry[]                 @relation("SeekerEnquiries")
  documents         UserDocument[]
  reports           Report[]
  messagesSent      Message[]                 @relation("MessagesSent")
  conversations     ConversationParticipant[]
  notifications     Notification[]
  payments          Payment[]
  auditEvents       AuditEvent[]
  sessions          AppSession[]
  agencyMemberships AgencyAgent[]
  academyApplications AcademyLearnerApplication[]
  academyResourceAccess AcademyResourceAccess[]
}

model Agency {
  id                 String             @id @default(cuid())
  name               String
  phone              String
  email              String
  city               String             @default("")
  verificationStatus VerificationStatus @default(PENDING)
  accountStatus      String             @default("ACTIVE")
  subscriptionTier   String             @default("FREE")
  revenue            Decimal            @default(0) @db.Decimal(12, 2)
  leadConversion     Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  listings           Listing[]
  agents             AgencyAgent[]
}

model AgencyAgent {
  agencyId  String
  userId    String
  title     String?
  createdAt DateTime @default(now())
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([agencyId, userId])
}

model Listing {
  id                         String                    @id @default(cuid())
  slug                       String                    @unique
  ownerId                    String
  agencyId                   String?
  intent                     ListingIntent
  propertyType               PropertyType
  status                     ListingStatus             @default(DRAFT)
  title                      String
  description                String
  price                      Decimal                   @db.Decimal(12, 2)
  currency                   String                    @default("USD")
  city                       String
  suburb                     String
  addressLine                String?
  latitude                   Decimal?                  @db.Decimal(10, 7)
  longitude                  Decimal?                  @db.Decimal(10, 7)
  bedrooms                   Int                       @default(0)
  bathrooms                  Int                       @default(0)
  furnished                  Boolean                   @default(false)
  parking                    Boolean                   @default(false)
  petFriendly                Boolean                   @default(false)
  wifi                       Boolean                   @default(false)
  solarBackup                Boolean                   @default(false)
  borehole                   Boolean                   @default(false)
  generator                  Boolean                   @default(false)
  waterTank                  Boolean                   @default(false)
  securityWall               Boolean                   @default(false)
  electricFence              Boolean                   @default(false)
  garden                     Boolean                   @default(false)
  swimmingPool               Boolean                   @default(false)
  availableFrom              DateTime?
  verifiedAt                 DateTime?
  featured                   Boolean                   @default(false)
  featuredUntil              DateTime?
  views                      Int                       @default(0)
  adminNotes                 String?
  expiresAt                  DateTime?
  leadSource                 LeadSource                @default(HOMELINK)
  leadCreatedById            String?
  assignedAgentId            String?
  propertyOwnerName          String?
  propertyOwnerEmail         String?
  propertyOwnerPhone         String?
  duplicateOwnerReviewStatus LeadOwnershipReviewStatus @default(NOT_REQUIRED)
  duplicateOwnerMatchId      String?
  ownerAgreementAccepted     Boolean                   @default(false)
  ownerAgreementSignedAt     DateTime?
  ownerAgreementSignerName   String?
  ownerAgreementVersion      String?
  ownerAgreementBypassedAt   DateTime?
  ownerAgreementBypassedById String?
  ownerAgreementBypassedByName String?
  ownerAgreementBypassedByEmail String?
  ownerAgreementBypassReason String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  owner                      User                      @relation(fields: [ownerId], references: [id])
  agency                     Agency?                   @relation(fields: [agencyId], references: [id])
  media                      ListingMedia[]
  favourites                 Favourite[]
  enquiries                  Enquiry[]
  reviews                    Review[]
  reports                    Report[]
  payments                   Payment[]
  viewingAppointments        ViewingAppointment[]
  signedAgreements           SignedAgreement[]
  marketInsightSnapshots     MarketInsightSnapshot[]
  neighbourhood              Neighbourhood?            @relation(fields: [neighbourhoodId], references: [id])
  neighbourhoodId            String?
  virtualTour                ListingVirtualTour?

  @@index([city, suburb])
  @@index([intent, propertyType, status])
  @@index([leadSource])
  @@index([assignedAgentId])
  @@index([propertyOwnerEmail])
  @@index([propertyOwnerPhone])
  @@index([price])
}

model ListingMedia {
  id        String   @id @default(cuid())
  listingId String
  url       String
  publicId  String
  mediaType String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingVirtualTour {
  id              String             @id @default(cuid())
  listingId       String             @unique
  title           String
  status          String             @default("DRAFT")
  provider        String             @default("INTERNAL")
  externalUrl     String?
  coverSceneId    String?
  adminVerifiedAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  listing         Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  scenes          VirtualTourScene[]
  events          VirtualTourEvent[]

  @@index([status])
}

model VirtualTourScene {
  id        String             @id @default(cuid())
  tourId    String
  title     String
  imageUrl  String
  sortOrder Int                @default(0)
  hotspots  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  tour      ListingVirtualTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, sortOrder])
}

model VirtualTourEvent {
  id        String             @id @default(cuid())
  tourId    String
  listingId String
  sceneId   String?
  eventType String
  metadata  Json?
  createdAt DateTime           @default(now())
  tour      ListingVirtualTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId, createdAt])
  @@index([listingId, createdAt])
  @@index([eventType])
}

model ViewingAppointment {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  listingId       String
  enquiryId       String?
  seekerId        String?
  seekerName      String
  seekerEmail     String?
  seekerPhone     String?
  agentId         String?
  agentName       String?
  startAt         DateTime
  endAt           DateTime
  status          String   @default("REQUESTED")
  location        String
  notes           String?
  reminderAt      DateTime?
  confirmedAt     DateTime?
  rescheduledAt   DateTime?
  cancelledAt     DateTime?
  completedAt     DateTime?
  auditTrail      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startAt])
  @@index([enquiryId])
  @@index([agentId, startAt])
  @@index([status])
}

model SignedAgreement {
  id             String   @id @default(cuid())
  subjectType    String
  subjectId      String
  listingId      String?
  title          String
  signerUserId   String?
  signerName     String
  signerEmail    String?
  signerRole     String
  signatureText  String
  agreementText  String
  contentHash    String
  pdfBase64      String
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  signedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  listing        Listing? @relation(fields: [listingId], references: [id])

  @@index([subjectType, subjectId])
  @@index([listingId])
  @@index([signerUserId])
  @@index([signedAt])
}

model MarketInsightSnapshot {
  id                   String   @id @default(cuid())
  city                 String
  suburb               String
  propertyType         String
  intent               String   @default("rent")
  listingId            String?
  sampleSize           Int      @default(0)
  medianPrice          Decimal  @default(0) @db.Decimal(12, 2)
  averagePrice         Decimal  @default(0) @db.Decimal(12, 2)
  recommendedPriceMin  Decimal  @default(0) @db.Decimal(12, 2)
  recommendedPriceMax  Decimal  @default(0) @db.Decimal(12, 2)
  demandScore          Int      @default(0)
  vacancyRisk          String   @default("UNKNOWN")
  comparableListingIds String[] @default([])
  payload              Json?
  createdAt            DateTime @default(now())
  listing              Listing? @relation(fields: [listingId], references: [id])

  @@index([city, suburb, propertyType])
  @@index([listingId])
  @@index([createdAt])
}

model Favourite {
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
}

model SavedSearch {
  id        String                @id @default(cuid())
  userId    String
  name      String
  query     Json
  channels  NotificationChannel[] @default([EMAIL])
  enabled   Boolean               @default(true)
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enquiry {
  id        String   @id @default(cuid())
  listingId String
  seekerId  String
  message   String
  channel   String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seeker    User     @relation("SeekerEnquiries", fields: [seekerId], references: [id], onDelete: Cascade)
}

/// Full CRM enquiry document — synced from runtime store when PostgreSQL is enabled.
model PropertyEnquiryRecord {
  id               String   @id
  subjectType      String   @default("LISTING")
  listingId        String?
  roommateUserId   String?
  holidayBookingId String?
  seekerId         String
  ownerId          String?
  status           String
  enquiryType      String
  assignedAgentId  String?
  payload          Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([seekerId])
  @@index([assignedAgentId])
  @@index([ownerId])
  @@index([subjectType])
  @@index([createdAt])
}

model ResidenceRecordRow {
  id             String   @id
  tenancyId      String
  userId         String
  counterpartyId String
  listingId      String?
  status         String
  verified       Boolean  @default(false)
  payload        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenancyId])
  @@index([userId])
  @@index([counterpartyId])
  @@index([listingId])
  @@index([status])
  @@index([verified])
}

model TenancyReferenceRow {
  id           String   @id
  tenancyId    String
  targetUserId String
  payload      Json
  createdAt    DateTime @default(now())

  @@index([tenancyId])
  @@index([targetUserId])
}

model TenancyDisputeRow {
  id        String   @id
  tenancyId String
  status    String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenancyId])
  @@index([status])
}

model PropertyManagementRequestRow {
  id            String   @id
  requestNumber String   @unique
  ownerId       String
  status        String
  consultantId  String?
  payload       Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([consultantId])
}

model HolidayBookingRecord {
  id          String   @id
  listingId   String
  guestUserId String
  ownerId     String?
  agentId     String?
  status      String
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([listingId])
  @@index([guestUserId])
  @@index([ownerId])
  @@index([agentId])
  @@index([status])
}

model AgentApplicationRecord {
  id        String   @id
  userId    String   @unique
  status    String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model AgentTrainingProgressRecord {
  id        String   @id @default(cuid())
  agentId   String
  moduleId  String
  status    String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, moduleId])
  @@index([agentId])
  @@index([status])
}

model AgentTrainingModuleRecord {
  id              String   @id
  title           String
  description     String
  type            String
  contentUrl      String?
  durationMinutes Int      @default(0)
  required        Boolean  @default(true)
  order           Int      @default(0)
  active          Boolean  @default(true)
  payload         Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
  @@index([required])
  @@index([order])
}

model Conversation {
  id           String                    @id @default(cuid())
  listingId    String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
}

model RoommateProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  budgetMin          Decimal         @db.Decimal(12, 2)
  budgetMax          Decimal         @db.Decimal(12, 2)
  occupation         String?
  genderPreference   String?
  lifestyle          String?
  smoking            Boolean         @default(false)
  pets               Boolean         @default(false)
  age                Int?
  preferredLocations String[]
  active             Boolean         @default(true)
  payload            Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchesAsSource    RoommateMatch[] @relation("RoommateSource")
  matchesAsCandidate RoommateMatch[] @relation("RoommateCandidate")
}

model RoommateMatch {
  id          String          @id @default(cuid())
  sourceId    String
  candidateId String
  score       Int
  reasons     String[]
  createdAt   DateTime        @default(now())
  source      RoommateProfile @relation("RoommateSource", fields: [sourceId], references: [id], onDelete: Cascade)
  candidate   RoommateProfile @relation("RoommateCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([sourceId, candidateId])
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  listingId String?
  rating    Int
  body      String
  target    String
  metadata  Json?
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  listing   Listing? @relation(fields: [listingId], references: [id])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String?
  listingId  String
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reporter   User?        @relation(fields: [reporterId], references: [id])
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model UserDocument {
  id        String             @id @default(cuid())
  userId    String
  url       String
  publicId  String
  type      String
  status    VerificationStatus @default(PENDING)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String          @id @default(cuid())
  userId      String
  listingId   String?
  provider    PaymentProvider
  status      PaymentStatus   @default(PENDING)
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("USD")
  description String
  externalId  String?
  plan        String?
  method      String?
  manual      Boolean         @default(false)
  proofUrl    String?
  proofStatus String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing?        @relation(fields: [listingId], references: [id])
  academyApplications AcademyLearnerApplication[]
  academyResourceAccess AcademyResourceAccess[]
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  status    NotificationStatus  @default(QUEUED)
  subject   String
  body      String
  createdAt DateTime            @default(now())
  sentAt    DateTime?
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Neighbourhood {
  id             String    @id @default(cuid())
  city           String
  suburb         String
  summary        String
  safetyScore    Int?
  waterScore     Int?
  transportScore Int?
  listings       Listing[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([city, suburb])
}

model AuditEvent {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String
  metadata  Json
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
}

model AppSession {
  id         String    @id
  userId     String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model LegalPageRecord {
  id            String   @id
  title         String
  summary       String
  body          String
  effectiveDate DateTime
  status        String
  savedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AgentLeadRecord {
  id                         String                    @id @default(cuid())
  listingId                  String?
  listingTitle               String?
  leadSource                 LeadSource                @default(HOMELINK)
  acquisitionChannel         String?
  createdById                String?
  createdByName              String?
  assignedAgentId            String?
  assignedAgentName          String?
  propertyOwnerId            String?
  propertyOwnerName          String?
  propertyOwnerEmail         String?
  propertyOwnerPhone         String?
  clientName                 String
  clientEmail                String?
  clientPhone                String?
  clientType                 String
  status                     String
  city                       String?
  suburb                     String?
  province                   String?
  notes                      String?
  duplicateOwnerReviewStatus LeadOwnershipReviewStatus @default(NOT_REQUIRED)
  duplicateOwnerMatchId      String?
  payload                    Json?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  commissions                AgentCommissionRecord[]
  ownershipAudits            LeadOwnershipAudit[]

  @@index([leadSource])
  @@index([assignedAgentId])
  @@index([propertyOwnerEmail])
  @@index([propertyOwnerPhone])
  @@index([status])
  @@index([createdAt])
}

model AgentCommissionRule {
  id                   String                  @id @default(cuid())
  type                 String
  label                String
  leadSource           LeadSource?
  scope                CommissionRuleScope     @default(DEFAULT)
  agentId              String?
  transactionId        String?
  branchId             String?
  propertyType         String?
  agentLevel           String?
  promotionCode        String?
  priority             Int                     @default(100)
  ratePercent          Decimal                 @db.Decimal(5, 2)
  homelinkSplitPercent Decimal                 @db.Decimal(5, 2)
  agentSplitPercent    Decimal                 @db.Decimal(5, 2)
  minAmount            Decimal                 @default(0) @db.Decimal(12, 2)
  maxAmount            Decimal                 @default(0) @db.Decimal(12, 2)
  vatPercent           Decimal                 @default(0) @db.Decimal(5, 2)
  bonusPercent         Decimal                 @default(0) @db.Decimal(5, 2)
  reason               String?
  active               Boolean                 @default(true)
  startsAt             DateTime?
  endsAt               DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  commissions          AgentCommissionRecord[]
  audits               CommissionAudit[]

  @@index([type, active])
  @@index([leadSource])
  @@index([scope])
  @@index([agentId])
  @@index([transactionId])
  @@index([branchId])
  @@index([propertyType])
  @@index([agentLevel])
  @@index([promotionCode])
}

model AgentCommissionRecord {
  id                  String                @id @default(cuid())
  leadId              String?
  listingId           String?
  agentId             String
  agentName           String
  type                String
  status              AgentCommissionStatus @default(PENDING)
  paymentStatus       AgentCommissionStatus @default(PENDING)
  dealRef             String
  leadSource          LeadSource            @default(HOMELINK)
  commissionRuleId    String?
  commissionRuleLabel String?
  commissionPercent   Decimal               @db.Decimal(5, 2)
  grossAmount         Decimal               @db.Decimal(12, 2)
  homelinkAmount      Decimal               @db.Decimal(12, 2)
  agentAmount         Decimal               @db.Decimal(12, 2)
  taxAmount           Decimal               @db.Decimal(12, 2)
  netAgentAmount      Decimal               @db.Decimal(12, 2)
  currency            String                @default("USD")
  ruleSnapshot        Json
  reason              String?
  approvedAt          DateTime?
  approvedBy          String?
  paidAt              DateTime?
  payout              Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  lead                AgentLeadRecord?      @relation(fields: [leadId], references: [id])
  rule                AgentCommissionRule?  @relation(fields: [commissionRuleId], references: [id])
  audits              CommissionAudit[]

  @@unique([dealRef])
  @@index([agentId])
  @@index([leadSource])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model LeadOwnershipAudit {
  id                 String          @id @default(cuid())
  leadId             String
  changedById        String
  changedByName      String
  oldLeadSource      LeadSource?
  newLeadSource      LeadSource
  oldAssignedAgentId String?
  newAssignedAgentId String?
  reason             String
  createdAt          DateTime        @default(now())
  lead               AgentLeadRecord @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([changedById])
  @@index([createdAt])
}

model CommissionAudit {
  id                      String                 @id @default(cuid())
  commissionId            String?
  ruleId                  String?
  changedById             String
  changedByName           String
  action                  String
  oldHomelinkSplitPercent Decimal?               @db.Decimal(5, 2)
  newHomelinkSplitPercent Decimal?               @db.Decimal(5, 2)
  oldAgentSplitPercent    Decimal?               @db.Decimal(5, 2)
  newAgentSplitPercent    Decimal?               @db.Decimal(5, 2)
