  id        String   @id @default("singleton")
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("training_settings")
}

model TrainingAuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([actorId])
  @@map("audit_logs")
}
