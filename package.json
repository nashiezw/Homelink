{
  "name": "homelink-zimbabwe",
  "version": "0.1.0",
  "private": true,
  "description": "Website-first property marketplace for Zimbabwe.",
  "workspaces": [
    "apps/api",
    "packages/domain"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "npm --workspace @homelink/api run typecheck",
    "check:content": "node scripts/check-content.mjs",
    "check:production": "node scripts/check-production-readiness.mjs",
    "db:audit:production": "node scripts/audit-production-db.mjs",
    "db:seed:production": "node scripts/seed-production.mjs",
    "db:seed:agent-training": "node scripts/seed-agent-training.mjs",
    "db:seed:academy-resources": "node scripts/seed-academy-resources.mjs",
    "db:seed:manual-course": "node scripts/seed-staged-course.mjs",
    "db:seed:staged-course": "node scripts/seed-staged-course.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "verify": "npm run typecheck && npm run build && node scripts/smoke-test.mjs",
    "postinstall": "prisma generate --schema prisma/settings.prisma && prisma generate --schema prisma/schema.prisma",
    "db:settings": "prisma db push --schema prisma/settings.prisma",
    "db:store": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
